{
  "name": "react-native-tailwind-nextjs",
  "version": "0.0.0-locked",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "lint": "pnpm -s normalize && pnpm -s eslint && pnpm -s stylelint && pnpm -s prettier && pnpm -s ts",
    "normalize": "node ./dev-tools normalize",
    "eslint": "node ./dev-tools eslint",
