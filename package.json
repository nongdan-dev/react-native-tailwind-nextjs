    "ts": "node ./dev-tools ts"
  },
  "engines": {
    "node": ">=24.11",
    "pnpm": ">=10"
  },
  "devDependencies": {
    "@types/node": "25.0",
    "json5": "2.2.3",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "typescript-plugin-css-modules": "5.2.0"
  },
  "pnpm": {
    "patchedDependencies": {}
  }
}
